# Generate RSA private key:
#   openssl genrsa 2048
# Put PEM on one line, replace newlines with \n:
#   AUTH_RSA_PRIVATE_KEY_PEM="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Required — login/signup password decryption
AUTH_RSA_PRIVATE_KEY_PEM=

# --- Billing / payments ----------------------------------------------------
# Public URL of the dashboard (PayOS/Payhip redirect targets).
APP_BASE_URL=http://localhost:3000

# PayOS (Vietnam) — required for region=vn checkout
# Webhook: POST {API_URL}/webhooks/payos
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
# PAYOS_API_BASE=https://api-merchant.payos.vn

# Payhip (international) — product links required for region=intl checkout
# Webhook: POST {API_URL}/webhooks/payhip
PAYHIP_API_KEY=
PAYHIP_WEBHOOK_SECRET=
PAYHIP_PRODUCT_LINK_PRO=
PAYHIP_PRODUCT_LINK_SCALE=